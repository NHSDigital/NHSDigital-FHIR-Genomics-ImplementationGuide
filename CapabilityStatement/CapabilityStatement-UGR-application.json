          "documentation": "For searching and retrieving Compositions and generating UGR Documents",
          "interaction": [
            {
              "code": "read"
            },
            {
              "code": "search-type"
            },
            {
              "code": "vread"
            },
            {
              "code": "history-instance"
            }
          ],
